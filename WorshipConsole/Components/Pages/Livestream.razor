@page "/livestream"
@using WorshipConsole.Services
@inject SettingsService SettingsService
@inject IJSRuntime JSRuntime

<PageTitle>Livestream | Worship Console</PageTitle>

<div class="container py-4">
    <div class="text-center mb-5">
        <h1 class="fw-bold text-white display-4">
            <i class="fa-solid fa-tower-broadcast text-teal me-3"></i>Livestream Control
        </h1>
        
        <!-- Livestream Setup Section -->
        <div class="mt-5">
            <div class="card navy-light-bg text-white border-secondary shadow">
                <div class="card-header border-secondary bg-dark p-3">
                    <h3 class="mb-0"><i class="fa-solid fa-file-signature text-teal me-2"></i>Livestream Setup</h3>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label text-teal fw-bold">Sermon Title</label>
                                <input type="text" class="form-control bg-dark text-white border-secondary" @bind="sermonTitle" @bind:event="oninput" placeholder="Enter sermon title..." />
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-teal fw-bold">Service Date</label>
                                <input type="date" class="form-control bg-dark text-white border-secondary" @bind="serviceDate" @bind:event="onchange" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-teal fw-bold">YouTube Live Link (for Facebook)</label>
                                <input type="text" class="form-control bg-dark text-white border-secondary" @bind="youtubeLiveLink" @bind:event="oninput" placeholder="https://youtube.com/live/..." />
                            </div>
                        </div>

                        <div class="col-md-8">
                            <div class="row">
                                <div class="col-12 mb-4">
                                    <label class="form-label text-teal fw-bold">Standardized Title (YouTube & Facebook)</label>
                                    <div class="input-group">
                                        <input type="text" class="form-control bg-dark text-white border-secondary" readonly value="@GeneratedTitle" />
                                        <button class="btn @(copyStatus == "title" ? "btn-success" : "btn-teal")" @onclick='() => CopyToClipboard(GeneratedTitle, "title")'>
                                            <i class="fa-solid @(copyStatus == "title" ? "fa-check" : "fa-copy")"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="col-md-6 mb-4">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <label class="form-label text-teal fw-bold mb-0">YouTube Description</label>
                                        <button class="btn btn-sm @(copyStatus == "youtube" ? "btn-success" : "btn-teal")" @onclick='() => CopyToClipboard(YoutubeDescription, "youtube")'>
                                            <i class="fa-solid @(copyStatus == "youtube" ? "fa-check" : "fa-copy") me-1"></i> @(copyStatus == "youtube" ? "Copied!" : "Copy")
                                        </button>
                                    </div>
                                    <textarea class="form-control bg-dark text-white border-secondary" rows="10" readonly>@YoutubeDescription</textarea>
                                </div>

                                <div class="col-md-6 mb-4">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <label class="form-label text-teal fw-bold mb-0">Facebook Description</label>
                                        <button class="btn btn-sm @(copyStatus == "facebook" ? "btn-success" : "btn-teal")" @onclick='() => CopyToClipboard(FacebookDescription, "facebook")'>
                                            <i class="fa-solid @(copyStatus == "facebook" ? "fa-check" : "fa-copy") me-1"></i> @(copyStatus == "facebook" ? "Copied!" : "Copy")
                                        </button>
                                    </div>
                                    <textarea class="form-control bg-dark text-white border-secondary" rows="10" readonly>@FacebookDescription</textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        <!-- OBS Control Card -->
        <div class="col-12 col-md-6 col-xl-5">
            <div class="card h-100 navy-light-bg text-white border-secondary feature-card shadow">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-dark rounded-circle p-3 me-3">
                            <img src="obs.png" class="obs-logo-medium" alt="OBS Logo" />
                        </div>
                        <h3 class="fw-bold mb-0">OBS Studio</h3>
                    </div>
                    
                    <p class="text-gray mb-4 flex-grow-1">
                        Control your livestream production directly. Switch scenes, start/stop the stream, manage recording, 
                        and monitor the live output with real-time screenshots.
                    </p>

                    <div class="mb-4">
                        <h6 class="text-teal text-uppercase fw-bold small mb-2">Instructions:</h6>
                        <ul class="text-gray small ps-3">
                            <li>Ensure OBS is running on the production computer.</li>
                            <li>Click "Connect" to sync with the OBS WebSocket server.</li>
                            <li>Use <strong>Studio Mode</strong> for previewing scenes before going live.</li>
                        </ul>
                    </div>

                    <a href="/obs" class="btn btn-teal-glow fw-bold py-3">
                        <i class="fa-solid fa-desktop me-2"></i>Open OBS Control
                    </a>
                </div>
            </div>
        </div>

        <!-- Camera Control Card -->
        <div class="col-12 col-md-6 col-xl-5">
            <div class="card h-100 navy-light-bg text-white border-secondary feature-card shadow">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-dark rounded-circle p-3 me-3 text-teal">
                            <i class="fa-solid fa-video fa-3x"></i>
                        </div>
                        <h3 class="fw-bold mb-0">PTZ Cameras</h3>
                    </div>
                    
                    <p class="text-gray mb-4 flex-grow-1">
                        Remotely manage your PTZ camera hardware. Adjust Pan, Tilt, and Zoom, toggle PoE power, 
                        and quickly recall your 9 position presets.
                    </p>

                    <div class="mb-4">
                        <h6 class="text-teal text-uppercase fw-bold small mb-2">Instructions:</h6>
                        <ul class="text-gray small ps-3">
                            <li>Verify camera network connectivity (IP Address config).</li>
                            <li>Toggle <strong>PoE Power</strong> if a camera needs to be rebooted.</li>
                            <li>Use the <strong>Numeric Keypad</strong> layout for quick preset recalls.</li>
                        </ul>
                    </div>

                    <div class="mt-auto d-flex gap-2">
                        <a href="/cameras" class="btn btn-outline-teal fw-bold py-3 flex-grow-1">
                            <i class="fa-solid fa-sliders me-2"></i>Open Camera Control
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 text-center">
        <div class="alert alert-secondary navy-light-bg border-secondary d-inline-block px-4 py-3">
            <i class="fa-solid fa-circle-info text-teal me-2"></i>
            <span class="text-gray">Settings for IP addresses and ports can be found in the <a href="/admin" class="text-teal">Administration</a> page. Secrets remain in <code>appsettings.json</code>.</span>
        </div>
    </div>
</div>

@code {
    private string sermonTitle = "";
    private DateTime serviceDate = DateTime.Today;
    private string youtubeLiveLink = "";
    private string churchName = "Corona SDA Church";
    private string youtubeHandle = "CoronaSDAChurch";
    private string facebookHandle = "CoronaSDAChurch";
    private string? copyStatus;

    protected override async Task OnInitializedAsync()
    {
        churchName = await SettingsService.GetSettingAsync("General", "ChurchName", "Corona SDA Church");
        youtubeHandle = await SettingsService.GetSettingAsync("General", "YouTubeHandle", "CoronaSDAChurch");
        facebookHandle = await SettingsService.GetSettingAsync("General", "FacebookHandle", "CoronaSDAChurch");
        
        // Default to today if Saturday, else next Saturday
        int daysUntilSaturday = ((int)DayOfWeek.Saturday - (int)DateTime.Today.DayOfWeek + 7) % 7;
        serviceDate = DateTime.Today.AddDays(daysUntilSaturday);
    }

    private string FormattedDate => GetFormattedDate(serviceDate);
    private string ServiceName => churchName.Replace(" Church", "").Trim() + " Worship";
    private string HandleName => churchName.Replace(" ", "").ToLower();

    private string GeneratedTitle => $"\"{sermonTitle}\" - {ServiceName} - {FormattedDate}";

    private string YoutubeDescription => $@"{sermonTitle}
{ServiceName}
{FormattedDate}

If you haven't already, please subscribe to our YouTube Channel so you don't miss our broadcasts: https://www.youtube.com/@{youtubeHandle}?sub_confirmation=1

#{youtubeHandle.Replace("Church", "").Replace("SDA", "")}";

    private string FacebookDescription => $@"{sermonTitle}
{ServiceName}
{FormattedDate}

Here is the link to the live broadcast on {youtubeLiveLink}
If you haven't already, please subscribe to our YouTube Channel so you don't miss our broadcasts: https://www.youtube.com/@{youtubeHandle}?sub_confirmation=1

Follow us on Facebook: https://facebook.com/{facebookHandle}";

    private string GetFormattedDate(DateTime date)
    {
        string day = date.Day.ToString();
        string suffix = (date.Day % 10) switch
        {
            1 when date.Day is not 11 => "st",
            2 when date.Day is not 12 => "nd",
            3 when date.Day is not 13 => "rd",
            _ => "th"
        };
        return $"{date:MMMM} {day}{suffix}, {date:yyyy}";
    }

    private async Task CopyToClipboard(string text, string statusKey)
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
        copyStatus = statusKey;
        StateHasChanged();
        
        // Reset status after 2 seconds
        await Task.Delay(2000);
        if (copyStatus == statusKey)
        {
            copyStatus = null;
            StateHasChanged();
        }
    }
}
