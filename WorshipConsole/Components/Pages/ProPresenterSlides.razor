@page "/slides"
@rendermode InteractiveServer

@inject ProPresenterService ProPresenter
@inject ILogger<ProPresenterSlides> Logger
@implements IDisposable

<PageTitle>ProPresenter Slides | Worship Console</PageTitle>

<div class="container py-4">
    @* ── Header ── *@
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center gap-3">
            <i class="fa-solid fa-images text-teal fs-2"></i>
            <h2 class="fw-bold text-white mb-0">Slides</h2>
        </div>
        <div class="d-flex align-items-center gap-2">
            @if (isConnected)
            {
                <span class="badge bg-success">● Connected</span>
            }
            else
            {
                <span class="badge bg-danger">● Disconnected</span>
            }
            <button class="btn btn-sm btn-outline-secondary" @onclick="CheckConnectionAsync" disabled="@isConnecting">
                <i class="fa-solid fa-arrows-rotate @(isConnecting ? "fa-spin" : "") me-1"></i>
            </button>
        </div>
    </div>

    @if (!ProPresenter.IsConfigured)
    {
        <div class="alert alert-warning border-warning navy-light-bg text-white">
            <h5 class="fw-bold"><i class="fa-solid fa-circle-exclamation me-2"></i> Not Configured</h5>
            ProPresenter is not configured. Please visit the <a href="/admin" class="text-teal">Administration</a> page to set the host and port.
        </div>
    }
    else if (!isConnected)
    {
        <div class="alert alert-danger border-danger navy-light-bg text-white">
            <h5 class="fw-bold"><i class="fa-solid fa-triangle-exclamation me-2"></i> Connection Failed</h5>
            <p class="mb-2">Unable to connect to ProPresenter.</p>
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="bg-dark bg-opacity-50 p-2 rounded small font-monospace border border-danger border-opacity-25 mb-2">
                    @statusMessage
                </div>
            }
            <button class="btn btn-sm btn-outline-light" @onclick="CheckConnectionAsync">Try Again</button>
        </div>
    }
    else
    {
        @* ── Main Control Area ── *@
        <div class="row g-4">
            @* Current Slide Preview *@
            <div class="col-12 col-lg-8">
                <div class="card navy-light-bg text-white border-secondary h-100 overflow-hidden shadow-lg">
                    <div class="card-header bg-dark border-secondary py-3 d-flex justify-content-between align-items-center">
                        <span class="fw-bold text-teal small text-uppercase tracking-wider">Current Slide</span>
                        <span class="badge bg-teal text-dark">LIVE</span>
                    </div>
                    <div class="card-body p-0 position-relative bg-black d-flex align-items-center justify-content-center current-slide-container">
                        @if (!string.IsNullOrEmpty(currentThumbnail))
                        {
                            <img src="@currentThumbnail" class="img-fluid w-100 h-100 object-fit-contain @(isUpdatingThumbnails ? "opacity-50" : "")" alt="Current Slide" />
                        }
                        else
                        {
                            <div class="text-center p-5">
                                <i class="fa-solid fa-display display-1 text-gray opacity-25 mb-3"></i>
                                <h4 class="text-gray fw-light">No Active Slide</h4>
                                <p class="text-gray small opacity-50">Select a slide in ProPresenter to begin.</p>
                            </div>
                        }
                        
                        @if (isUpdatingThumbnails)
                        {
                            <div class="position-absolute top-50 start-50 translate-middle">
                                <div class="spinner-border text-teal" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                        }
                        
                        <div class="position-absolute bottom-0 start-0 end-0 p-4 bg-gradient-dark-top d-flex justify-content-between align-items-end">
                            <div class="text-start">
                                <h5 class="mb-0 fw-bold text-shadow">@(presentationName ?? "Active Presentation")</h5>
                                <span class="text-teal small text-shadow">Slide @(currentSlideIndex >= 0 ? (currentSlideIndex + 1).ToString() : "—")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Quick Controls *@
            <div class="col-12 col-lg-4">
                <div class="d-flex flex-column gap-4 h-100">
                    @* Transport Controls *@
                    <div class="card navy-light-bg text-white border-secondary shadow">
                        <div class="card-body p-4 text-center">
                            <h5 class="text-gray small text-uppercase tracking-wider mb-4">Playback</h5>
                            <div class="d-grid gap-3">
                                
                                @* Next Button with Thumbnail *@
                                <div class="thumbnail-btn-container mb-2">
                                    <div class="thumbnail-preview mb-1 @(string.IsNullOrEmpty(nextThumbnail) ? "d-none" : "")">
                                        <img src="@nextThumbnail" class="rounded border border-secondary @(isUpdatingThumbnails ? "opacity-50" : "")" alt="Next Slide" />
                                        <div class="thumbnail-label">NEXT</div>
                                    </div>
                                    <button class="btn btn-lg btn-teal-glow py-4 w-100 shadow-sm" @onclick="NextSlideAsync" disabled="@isConnecting">
                                        <i class="fa-solid fa-forward-step fs-2 mb-2 d-block"></i>
                                        <span class="fw-bold">NEXT SLIDE</span>
                                    </button>
                                </div>
                                
                                <div class="row g-3">
                                    <div class="col-6 text-center">
                                        @* Prev Button with Thumbnail *@
                                        <div class="thumbnail-preview-mini mb-2 @(string.IsNullOrEmpty(prevThumbnail) ? "d-none" : "")">
                                            <img src="@prevThumbnail" class="rounded border border-secondary w-100 @(isUpdatingThumbnails ? "opacity-50" : "")" alt="Prev Slide" />
                                            <div class="thumbnail-label-mini">PREV</div>
                                        </div>
                                        <button class="btn btn-outline-secondary w-100 py-3" @onclick="PreviousSlideAsync" disabled="@isConnecting">
                                            <i class="fa-solid fa-backward-step me-2"></i> Prev
                                        </button>
                                    </div>
                                    <div class="col-6">
                                        <div class="mt-auto h-100 d-flex flex-column justify-content-end">
                                            <button class="btn btn-outline-danger w-100 py-3" @onclick="ClearSlideAsync" title="Clear Presentation Layer" disabled="@isConnecting">
                                                <i class="fa-solid fa-circle-xmark me-2"></i> Clear
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Clear All Button *@
                    <button class="btn btn-danger btn-lg py-3 shadow" @onclick="ClearAllAsync" disabled="@isConnecting">
                        <i class="fa-solid fa-bomb me-2"></i> CLEAR ALL LAYERS
                    </button>
                </div>
            </div>
        </div>
    }

    <div class="mt-4">
        <a href="/propresenter" class="btn btn-outline-secondary">
            <i class="fa-solid fa-arrow-left me-1"></i> Back to Control Hub
        </a>
    </div>
</div>

@code {
    private bool isConnected;
    private bool isConnecting;
    private bool isUpdatingThumbnails;
    private string? statusMessage;
    private PeriodicTimer? pollTimer;
    private CancellationTokenSource? cts;

    private int currentSlideIndex = -1;
    private string? presentationUuid;
    private string? presentationName;
    private string? currentThumbnail;
    private string? nextThumbnail;
    private string? prevThumbnail;
    
    private DateTime lastThumbnailUpdate = DateTime.MinValue;

    protected override async Task OnInitializedAsync()
    {
        await CheckConnectionAsync();
        
        // Polling loop - 2 seconds is much more reasonable
        cts = new CancellationTokenSource();
        _ = PollStatusAsync(cts.Token);
    }

    private async Task PollStatusAsync(CancellationToken token)
    {
        pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        try
        {
            while (await pollTimer.WaitForNextTickAsync(token))
            {
                await RefreshStatusAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task RefreshStatusAsync(bool forceThumbnails = false)
    {
        (bool Success, string Message) status = await ProPresenter.GetStatusAsync();
        isConnected = status.Success;
        statusMessage = status.Message;

        if (isConnected)
        {
            (string? Uuid, string? Name, int? Index) details = await ProPresenter.GetActivePresentationDetailsAsync();
            
            bool uuidChanged = details.Uuid != presentationUuid;
            bool indexChanged = details.Index != currentSlideIndex;
            bool intervalPassed = (DateTime.Now - lastThumbnailUpdate).TotalSeconds >= 5;

            if (uuidChanged || indexChanged || forceThumbnails || (intervalPassed && !string.IsNullOrEmpty(presentationUuid)))
            {
                presentationUuid = details.Uuid;
                presentationName = details.Name;
                currentSlideIndex = details.Index ?? -1;
                
                await UpdateThumbnailsAsync();
                lastThumbnailUpdate = DateTime.Now;
            }
        }
        else
        {
            presentationUuid = null;
            presentationName = null;
            currentSlideIndex = -1;
            currentThumbnail = null;
            nextThumbnail = null;
            prevThumbnail = null;
        }
    }

    private async Task UpdateThumbnailsAsync()
    {
        if (string.IsNullOrEmpty(presentationUuid) || currentSlideIndex < 0)
        {
            currentThumbnail = null;
            nextThumbnail = null;
            prevThumbnail = null;
            return;
        }

        isUpdatingThumbnails = true;
        StateHasChanged();

        try
        {
            // Exact working path: v1/presentation/{uuid}/thumbnail/{index}
            Task<string?> currentTask = ProPresenter.GetThumbnailAsync($"v1/presentation/{presentationUuid}/thumbnail/{currentSlideIndex}");
            Task<string?> nextTask = ProPresenter.GetThumbnailAsync($"v1/presentation/{presentationUuid}/thumbnail/{currentSlideIndex + 1}");
            Task<string?> prevTask = currentSlideIndex > 0 
                ? ProPresenter.GetThumbnailAsync($"v1/presentation/{presentationUuid}/thumbnail/{currentSlideIndex - 1}")
                : Task.FromResult<string?>(null);

            await Task.WhenAll(currentTask, nextTask, prevTask);

            currentThumbnail = await currentTask;
            nextThumbnail = await nextTask;
            prevThumbnail = await prevTask;
        }
        finally
        {
            isUpdatingThumbnails = false;
        }
    }

    private async Task CheckConnectionAsync()
    {
        isConnecting = true;
        statusMessage = null;
        StateHasChanged();
        try
        {
            (bool Success, string Message) result = await ProPresenter.GetStatusAsync();
            isConnected = result.Success;
            statusMessage = result.Message;
            if (isConnected)
            {
                await RefreshStatusAsync(true);
            }
        }
        finally
        {
            isConnecting = false;
            StateHasChanged();
        }
    }

    private async Task NextSlideAsync()
    {
        await ProPresenter.NextSlideAsync();
        await Task.Delay(200); 
        await RefreshStatusAsync(true);
    }

    private async Task PreviousSlideAsync()
    {
        await ProPresenter.PreviousSlideAsync();
        await Task.Delay(200);
        await RefreshStatusAsync(true);
    }

    private async Task ClearSlideAsync()
    {
        await ProPresenter.ClearSlideAsync();
        await Task.Delay(200);
        await RefreshStatusAsync(true);
    }

    private async Task ClearAllAsync()
    {
        await ProPresenter.ClearAllAsync();
        await Task.Delay(200);
        await RefreshStatusAsync(true);
    }

    public void Dispose()
    {
        cts?.Cancel();
        cts?.Dispose();
        pollTimer?.Dispose();
    }
}
