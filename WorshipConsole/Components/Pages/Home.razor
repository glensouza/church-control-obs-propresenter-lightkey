@page "/"

<PageTitle>Worship Console | Unified AV Control</PageTitle>

<section class="hero text-center py-5">
    <div class="container py-5">
        <h1 class="display-4 fw-bold mb-3">The Single-Fader Sanctuary:<br>Command the Entire Service.</h1>
        <p class="lead text-gray mb-5">Unify OBS, ProPresenter, and Lightkey with intuitive simplicity. Less friction, more worship.</p>

        <div class="mockup-placeholder mx-auto d-flex flex-column align-items-center justify-content-center rounded-4 shadow-lg mb-5">
            <img src="@Assets["android-chrome-512x512.png"]" style="max-height: 350px;" alt="Logo" />
            @*
            <i class="fa-solid fa-tablet-screen-button display-1 text-teal mb-3"></i>
            <p class="text-muted">Tablet UI Mockup Goes Here</p>
            *@
        </div>

        @* <button class="btn btn-teal-glow rounded-pill px-5 py-3 fw-bold" onclick="triggerAlert()">GET FREE TRIAL</button> *@
    </div>
</section>

<section id="features" class="py-5">
    <div class="container py-5">
        <h2 class="text-center fw-bold mb-5">Worship Without Chaos</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 navy-light-bg text-center text-white border-secondary p-4 feature-card">
                    <div class="card-body">
                        <img src="@Assets["obs.png"]" style="height: 88px;" alt="OBS" />
                        @* <i class="fa-solid fa-video display-5 text-teal mb-4"></i> *@
                        <h3 class="h4 fw-bold">OBS</h3>
                        <p class="text-gray mb-0">Streamline Broadcasting. Control scenes, audio, and transitions with a single tap.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 navy-light-bg text-center text-white border-secondary p-4 feature-card">
                    <div class="card-body">
                        <img src="@Assets["propresenter.png"]" style="height: 88px;" alt="ProPresenter" />
                        @* <i class="fa-solid fa-desktop display-5 text-teal mb-4"></i> *@
                        <h3 class="h4 fw-bold">ProPresenter</h3>
                        <p class="text-gray mb-0">Manage Presentation. Advance slides and trigger media seamlessly during the service.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 navy-light-bg text-center text-white border-secondary p-4 feature-card">
                    <div class="card-body">
                        <img src="@Assets["lightkey.png"]" style="height: 88px;" loading="lazy" alt="Lightkey" />
                        @* <i class="fa-regular fa-lightbulb display-5 text-teal mb-4"></i> *@
                        <h3 class="h4 fw-bold">Lightkey</h3>
                        <p class="text-gray mb-0">Master Lighting. Trigger cues and adjust intensities without jumping between apps.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

