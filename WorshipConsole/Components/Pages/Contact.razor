@page "/contact"
@inject PcoApiService PcoApiService

<PageTitle>Contact | Worship Console</PageTitle>

<section class="py-5">
    <div class="container py-4">
        <h2 class="fw-bold mb-2">Service Contacts</h2>
        <p class="text-gray mb-5">Technology team members scheduled for the next Saturday service, pulled live from Planning Center Online.</p>

        @if (!_isConfigured)
        {
            <div class="alert alert-warning d-flex align-items-center gap-3" role="alert">
                <i class="fa-solid fa-triangle-exclamation fs-4"></i>
                <div>
                    Planning Center Online credentials are not configured. Please set <code>Pco:AppId</code>,
                    <code>Pco:AppSecret</code>, and <code>Pco:ServiceTypeId</code> in your application settings.
                </div>
            </div>
        }
        else if (_isLoading)
        {
            <div class="d-flex align-items-center gap-3 text-gray">
                <div class="spinner-border spinner-border-sm text-teal" role="status">
                    <span class="visually-hidden">Loading…</span>
                </div>
                <span>Loading contacts from Planning Center Online…</span>
            </div>
        }
        else if (_error != null)
        {
            <div class="alert alert-danger d-flex align-items-center gap-3" role="alert">
                <i class="fa-solid fa-circle-exclamation fs-4"></i>
                <div>@_error</div>
            </div>
        }
        else if (_contacts == null)
        {
            <div class="alert alert-secondary" role="alert">
                No upcoming Saturday service was found in Planning Center Online.
            </div>
        }
        else
        {
            <p class="text-teal fw-semibold mb-4">
                <i class="fa-regular fa-calendar me-2"></i>Next Saturday: @_contacts.ServiceDates
            </p>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card h-100 navy-light-bg text-white border-secondary p-4 feature-card">
                        <div class="card-body text-center">
                            <i class="fa-solid fa-desktop display-5 text-teal mb-3"></i>
                            <h5 class="fw-bold mb-1">ProPresenter</h5>
                            <p class="text-gray small mb-3">Slides &amp; Media Operator</p>
                            <p class="fs-5 mb-0">@(_contacts.ProPresenter ?? "Not assigned")</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 navy-light-bg text-white border-secondary p-4 feature-card">
                        <div class="card-body text-center">
                            <i class="fa-solid fa-video display-5 text-teal mb-3"></i>
                            <h5 class="fw-bold mb-1">Livestream</h5>
                            <p class="text-gray small mb-3">Livestream Operator</p>
                            <p class="fs-5 mb-0">@(_contacts.Livestream ?? "Not assigned")</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 navy-light-bg text-white border-secondary p-4 feature-card">
                        <div class="card-body text-center">
                            <i class="fa-regular fa-lightbulb display-5 text-teal mb-3"></i>
                            <h5 class="fw-bold mb-1">Lights</h5>
                            <p class="text-gray small mb-3">Worship Coordinator</p>
                            <p class="fs-5 mb-0">@(_contacts.WorshipCoordinator ?? "Not assigned")</p>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@code {
    private bool _isLoading = true;
    private bool _isConfigured;
    private ContactInfo? _contacts;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _isConfigured = PcoApiService.IsConfigured();
        if (!_isConfigured)
        {
            _isLoading = false;
            return;
        }

        try
        {
            _contacts = await PcoApiService.GetNextSaturdayContactsAsync();
        }
        catch (Exception ex)
        {
            _error = $"An error occurred while loading contacts: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
